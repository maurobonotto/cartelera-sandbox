    "id_funcion": "lugones_LA_NOCHE_ESTÁ_MARCHÁNDOSE_YA_La_noche_está_marchándose_ya_JUE 4-JUN-2026_2030",
    "titulo": "La noche está marchándose ya",
    "director": "María Aparicio",
    "duracion": "N/A",
    "cine": "Sala Leopoldo Lugones",
